# Pixel AI — Secrets Configuration
# Copy this to secrets.toml and fill in your values.
# secrets.toml is .gitignore'd — never commit it.

# API Keys
GROQ_API_KEY = "gsk_your_key_here"
ANTHROPIC_API_KEY = "sk-ant-your-key-here"
GOOGLE_API_KEY = "AIza-your-key-here"

# Provider Settings
PREFERRED_PROVIDER = "groq"        # ollama | groq | gemini | claude
OLLAMA_MODEL = "llama3.2"
SMART_MODE = false

# Rate Limit Settings
RATE_LIMIT_COOLDOWN = 60           # seconds to wait after a 429 before retrying a provider

# Search Engine (for search skill)
SEARCH_ENGINE = "duckduckgo"       # google | bing | duckduckgo
